<h1>New User Account</h1>

<% if flash["notice"] %>
  <p style="color: red;"><%= flash["notice"] %></p>
<% end %>

<form action="/users" method="post">
  <p>
    <label for="first_name_input">First Name</label>
    <input type="text" name="first_name" id="first_name_input">

    <label for="last_name_input">Last Name</label>
    <input type="text" name="last_name" id="last_name_input">
  </p>
  
  <p>
    <label for="email_input">Email</label>
    <input type="text" name="email" id="email_input">

    <label for="password_input">Password</label>
    <div style="position: relative; display: inline-block;">
      <input type="password" name="password" id="password_input" style="padding-right: 2rem;">
      <button type="button" onclick="togglePassword('password_input', this)" style="position: absolute; right: 0.3rem; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; padding: 0; color: inherit;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
      </button>
    </div>
  </p>
  
  <button>Signup</button>
</form>